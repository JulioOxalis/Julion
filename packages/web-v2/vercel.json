{
  "version": 2,
  "framework": null,
  "outputDirectory": "public",
  "buildCommand": "",
  "rewrites": [
    { "source": "/dashboard",    "destination": "/pages/dashboard.html" },
    { "source": "/repositories", "destination": "/pages/repositories.html" },
    { "source": "/repository",   "destination": "/pages/repository.html" },
    { "source": "/auth-complete","destination": "/pages/auth-complete.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "DENY" },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
