{
  "version": 2,
  "framework": null,
  "outputDirectory": "public",
  "buildCommand": "",
"rewrites": [
    { "source": "/auth/callback",   "destination": "/api/auth/callback" },
    { "source": "/how-it-works",    "destination": "/pages/how-it-works.html" },
    { "source": "/features",        "destination": "/pages/features.html" },
    { "source": "/dashboard",       "destination": "/pages/dashboard.html" },
    { "source": "/repositories", "destination": "/pages/repositories.html" },
    { "source": "/repository",   "destination": "/pages/repository.html" },
    { "source": "/auth-complete","destination": "/pages/auth-complete.html" },
    { "source": "/capyrel",     "destination": "/pages/capyrel.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "DENY" },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
