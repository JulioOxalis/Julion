# Google OAuth (from Google Cloud Console)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
# Site root OR full callback URL (callback is auto-built if you only set the site root)
GOOGLE_REDIRECT_URI=https://julion.julio.co.tz

# Public site URL (used for links and OAuth callback when redirect is only a domain)
JULION_SITE_URL=https://julion.julio.co.tz
JULION_WEBSITE_AUTH_URL=https://julion.julio.co.tz/auth/google

# MySQL (Laragon default: root with empty password)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_DATABASE=julion

# Web server
PORT=3000
SESSION_SECRET=change-this-to-a-long-random-string
NODE_ENV=development
