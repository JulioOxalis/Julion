# ── MongoDB Atlas (primary database — replaces MySQL) ──────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.xxxxx.mongodb.net/?retryWrites=true&w=majority
DB_NAME=julion

# ── Google OAuth (from Google Cloud Console) ───────────────────────────────────
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
# Must match exactly what you registered in Google Cloud Console
# For serverless (web-v2): https://your-app.vercel.app/api/auth/callback
# For Express (web):        https://your-domain.com/auth/google/callback
GOOGLE_REDIRECT_URI=https://julion.julio.co.tz/api/auth/callback

# ── Public site URL ────────────────────────────────────────────────────────────
JULION_SITE_URL=https://julion.julio.co.tz
JULION_WEBSITE_AUTH_URL=https://julion.julio.co.tz/api/auth/google

# ── JWT session (web-v2 serverless only) ──────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string

# ── Web server (Express / web package only) ────────────────────────────────────
PORT=3000
SESSION_SECRET=change-this-to-a-long-random-string
NODE_ENV=development

# ── Legacy MySQL (kept for reference — no longer used) ────────────────────────
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=
# DB_DATABASE=julion
